# MongoDB Atlas connection string (Atlas -> Connect -> Drivers).
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DATABASE=movielist

# Enables the Claude-powered AI features (summary, sentiment, NL search, recommendations).
# Get a key at https://console.anthropic.com/ . Leave blank to run without AI.
ANTHROPIC_API_KEY=