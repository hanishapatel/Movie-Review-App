# MongoDB Atlas connection string (Atlas -> Connect -> Drivers).
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DATABASE=movielist

# Enables the Claude-powered AI features (summary, sentiment, NL search, recommendations).
# Get a key at https://console.anthropic.com/ . Leave blank to run without AI.
ANTHROPIC_API_KEY=

# Auto-seeds the catalog on first startup IF the database is empty. Set ONE key.
#
# OMDb — posters are Amazon-hosted, so they load even where TMDB is blocked
# (e.g. some Indian ISPs). Free key by email: https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=
#
# TMDB — richer (trailers/backdrops), but blocked on some ISPs.
# Free key: https://www.themoviedb.org/settings/api
TMDB_API_KEY=
#
# How many movies to auto-seed (default 100).
SEED_COUNT=100